# =============================================================================
# .env.example — AI Trading Agent V2 (Thesis Edition)
# =============================================================================
# Template per le variabili di ambiente del progetto V2.
# Tutte le env vars usano prefisso AIAT_ (vedi PRD V2 §11.4).
#
# Copia questo file in .env e compila i valori. NON committare mai .env
# (deve essere ignorato da .gitignore).
#
# Le variabili sono raggruppate per ruolo:
# - [COMMON] tutti i 5 servizi (agent + context-orchestrator)
# - [AGENT-ONLY] solo i 4 servizi agent
# - [ORCHESTRATOR-ONLY] solo il servizio context-orchestrator
#
# Per sviluppo locale: setta AIAT_SERVICE_ROLE=agent o context_orchestrator
# e popola le sezioni corrispondenti.
# =============================================================================


# -----------------------------------------------------------------------------
# [COMMON] — comune a tutti i 5 servizi
# -----------------------------------------------------------------------------

# Identity dell'esperimento (UUID, generato al seed)
AIAT_EXPERIMENT_ID=00000000-0000-0000-0000-000000000000

# Git commit SHA, iniettato a build-time da CI
AIAT_GIT_COMMIT_SHA=local-dev

# Database Postgres condiviso
# Format: postgresql+asyncpg://user:password@host:port/dbname
AIAT_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/aiat_v2

# Network locked (invariante #9: solo testnet)
AIAT_NETWORK=testnet

# Observability
AIAT_LOG_LEVEL=INFO

# Service role discriminator: "agent" oppure "context_orchestrator"
AIAT_SERVICE_ROLE=agent


# -----------------------------------------------------------------------------
# [AGENT-ONLY] — solo per i 4 servizi agent
# (Lascia tutto vuoto se AIAT_SERVICE_ROLE=context_orchestrator)
# -----------------------------------------------------------------------------

# Identity del modello (uno dei 4: openai/anthropic/deepseek/qwen × premium/cheap)
AIAT_MODEL_ID=openai-<model-name>
AIAT_PROMPT_TEMPLATE_HASH=<sha256-from-prompt_templates-table>
AIAT_SCHEMA_VERSION=v1

# LLM provider config
AIAT_LLM_PROVIDER=openai
AIAT_MODEL_NAME_API=<exact-api-string>
AIAT_TEMPERATURE=0
AIAT_SEED=42
AIAT_MAX_TOKENS=4096
# AIAT_TOP_P=1.0   # opzionale

# LLM API keys: solo UNA è attesa (corrispondente a AIAT_LLM_PROVIDER)
# Le altre devono essere ASSENTI o commentate (least privilege)
AIAT_OPENAI_API_KEY=sk-...
# AIAT_ANTHROPIC_API_KEY=sk-ant-...
# AIAT_DEEPSEEK_API_KEY=sk-...
# AIAT_QWEN_API_KEY=sk-...

# Hyperliquid wallet (uno per modello, 4 wallet distinti per i 4 agent)
AIAT_HL_WALLET_PRIVATE_KEY=0x...
AIAT_HL_WALLET_ADDRESS=0x...

# Guardrails Strategia C+ (PRE_PRD §13.3, invariante #8 sempre attivi)
AIAT_MAX_SIZE_PCT=0.20
AIAT_HARD_MAX_LEVERAGE=10
AIAT_MIN_OPEN_CONFIDENCE=0.4

# Context (invariante #5: Memoria 2 OFF di default per tesi)
AIAT_INJECT_DECISION_HISTORY=false

# Scheduling
AIAT_AGENT_START_DELAY_SECONDS=30
AIAT_HARD_TIMEOUT_SECONDS=180


# -----------------------------------------------------------------------------
# [ORCHESTRATOR-ONLY] — solo per il 5° servizio context-orchestrator
# (Lascia tutto vuoto se AIAT_SERVICE_ROLE=agent)
# -----------------------------------------------------------------------------

# Cron offsets per APScheduler (default: minuti 0/15/30/45)
# AIAT_CRON_MINUTE_OFFSETS=0,15,30,45

# Hard timeout (più stretto degli agent: deve completare prima dei 4 agent)
# AIAT_HARD_TIMEOUT_SECONDS=30  # override del default se serve

# Opzionale: API key per news premium (se non presente, free tier)
# AIAT_NEWSFEED_API_KEY=...


# =============================================================================
# WARNING: SECURITY
# =============================================================================
# - MAI committare .env con valori reali
# - Verifica che .gitignore contenga .env
# - Sui servizi Railway, usa Sealed Variables per tutte le _KEY e _PRIVATE_KEY
# - Le 4 API keys LLM e i 4 wallet HL sono distribuiti tra i 4 agent
#   (uno per servizio, non tutti in un .env locale unico)
# =============================================================================
