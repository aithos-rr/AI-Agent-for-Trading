# === LLM Provider ===
OPENAI_API_KEY=your_openai_api_key_here

# === Market Data ===
CMC_PRO_API_KEY=your_coinmarketcap_pro_api_key_here

# === Database ===
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === Hyperliquid Wallet ===
# WARNING: PRIVATE_KEY is the wallet's private key. Never commit, never share.
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY_HERE
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE
